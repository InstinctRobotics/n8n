        "jsCode": "const base_data = {\n    \"position\": {\"x\": -0.1, \"y\": 0.4, \"z\": 0.3},\n    \"orientation\": {\"x\": 0.5, \"y\": 0.5, \"z\": 0.5, \"w\": -0.5}\n};\n\nconst p_delta = 0.05; \nconst o_delta = 0.02;\n\nfunction jitter(val, delta) {\n    return Number((val + (Math.random() * (delta * 2) - delta)).toFixed(4));\n}\n\nconst new_pose = {\n    \"position\": {\n        \"x\": jitter(base_data.position.x, p_delta),\n        \"y\": jitter(base_data.position.y, p_delta),\n        \"z\": jitter(base_data.position.z, p_delta)\n    },\n    \"orientation\": {\n        \"x\": jitter(base_data.orientation.x, o_delta),\n        \"y\": jitter(base_data.orientation.y, o_delta),\n        \"z\": jitter(base_data.orientation.z, o_delta),\n        \"w\": jitter(base_data.orientation.w, o_delta)\n    }\n};\n\nreturn { json: {\"pose\":new_pose} };"
